# EarthMind Intelligence Core - Configuration
# Copy this file to .env and fill in your values

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Database
DATABASE_URL=sqlite:///./earthmind.db

# AI / LLM Configuration (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Satellite Providers (Optional)
SENTINEL_HUB_CLIENT_ID=your_id_here
SENTINEL_HUB_CLIENT_SECRET=your_secret_here

# Security
SECRET_KEY=generate_a_secure_key_for_production
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
